# Copy to .env and fill in. NEVER commit the real .env (it is gitignored).

# --- Mercury (read-only API token) ---
# Generate in Mercury: Settings → API tokens → create a READ-ONLY token.
MERCURY_API_TOKEN=

# --- Slack delivery (Incoming Webhook) ---
# Create a Slack app → Incoming Webhooks → Add to a PRIVATE channel → copy URL.
SLACK_WEBHOOK_URL=

# --- Formatting ---
# IANA timezone used for the date label in the report.
TIMEZONE=America/Phoenix
